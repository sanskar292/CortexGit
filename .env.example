# Database URL for CortexGit persistence (SQLite by default, can also be PostgreSQL+asyncpg)
DATABASE_URL=sqlite+aiosqlite:///cortexgit.db

# Alternatively, use PostgreSQL with asyncpg driver (requires pgvector extension for native search):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cortexgit

# Anthropic API Key used for running Anthropic models (e.g. Claude Sonnet)
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI API Key used for running OpenAI models (e.g. GPT-4, text-embedding-3-small)
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Ollama local configuration (assumes local Ollama instance running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Active Multi-Provider LLM settings (anthropic, openai, openrouter, ollama)
CORTEXGIT_LLM_PROVIDER=openai
CORTEXGIT_EMBEDDING_PROVIDER=openai

