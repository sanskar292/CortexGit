# Database URL for CortexGit persistence (SQLite by default, can also be PostgreSQL+asyncpg)
DATABASE_URL=sqlite+aiosqlite:///cortexgit.db

# Alternatively, use PostgreSQL with asyncpg driver (requires pgvector extension for native search):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cortexgit

# Anthropic API Key used for running Anthropic models (e.g. Claude Sonnet)
ANTHROPIC_API_KEY=your_key_here

# OpenAI API Key used for running OpenAI models (e.g. GPT-4, text-embedding-3-small)
OPENAI_API_KEY=your_key_here
